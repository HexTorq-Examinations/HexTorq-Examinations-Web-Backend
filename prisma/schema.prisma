generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STUDENT
}

model Organization {
  id         String   @id @default(cuid())
  name       String
  code       String   @unique
  domain     String?
  adminEmail String
  status     String   @default("Active")
  plan       String   @default("Basic")
  createdAt  DateTime @default(now())

  users   User[]
  exams   Exam[]
  results Result[]
  batches Batch[]
}

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  passwordHash     String
  role             Role
  phone            String?
  employeeId       String?
  avatar           String?
  status           String    @default("Active")
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  lastLoginAt      DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())

  studentProfile StudentProfile?
  examAttempts   ExamAttempt[]

  createdConversations Conversation[]            @relation("ConversationCreator")
  conversations        ConversationParticipant[]
  messages             Message[]
}

enum ConversationType {
  DIRECT
  GROUP
}

model Conversation {
  id          String           @id @default(cuid())
  type        ConversationType
  name        String? // group name; unused for DIRECT
  classId     String?          @unique // set for the auto-managed per-Class announcement group
  createdById String
  createdBy   User             @relation("ConversationCreator", fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  text           String
  createdAt      DateTime     @default(now())
}

// ---- Academic hierarchy: Batch -> School -> Department -> Class -> Student ----
// Strictly linear, all scoped to one Organization, managed only by that org's Admin.

model Batch {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  schools School[]
}

model School {
  id        String   @id @default(cuid())
  name      String
  batchId   String
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  departments Department[]
}

model Department {
  id        String   @id @default(cuid())
  name      String
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  classes Class[]
}

model Class {
  id           String     @id @default(cuid())
  name         String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  students      StudentProfile[]
  examMappings  ExamMapping[]
}

model StudentProfile {
  id             String @id @default(cuid())
  userId         String @unique
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  registerNumber String
  classId        String
  class          Class  @relation(fields: [classId], references: [id], onDelete: Restrict)
}

model Question {
  id            String   @id @default(cuid())
  text          String
  subject       String
  type          String   @default("Multiple Choice")
  difficulty    String   @default("Medium")
  marks         Int      @default(1)
  options       String[]
  correctAnswer Int      @default(0)
  explanation   String?
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model Exam {
  id               String   @id @default(cuid())
  title            String
  subject          String
  description      String?
  duration         Int
  totalMarks       Int
  passingMarks     Int
  status           String   @default("Draft")
  shuffleQuestions Boolean  @default(false)
  shuffleOptions   Boolean  @default(false)
  negativeMarking  Boolean  @default(false)
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  questions Question[]
  mappings  ExamMapping[]
  results   Result[]
  attempts  ExamAttempt[]
}

// Assigns an Exam to a Class with its own date/time — this is what actually
// schedules the exam for real students. One exam can have many mappings.
model ExamMapping {
  id        String   @id @default(cuid())
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  date      DateTime
  startTime String
  endTime   String
  hall      String   @default("Virtual")
  status    String   @default("Scheduled")
  createdAt DateTime @default(now())

  @@unique([examId, classId])
}

model Result {
  id             String    @id @default(cuid())
  examId         String
  exam           Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  totalStudents  Int       @default(0)
  publishedDate  DateTime?
  status         String    @default("Pending Evaluation")
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
}

model ExamAttempt {
  id         String    @id @default(cuid())
  examId     String
  exam       Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     String    @default("IN_PROGRESS")
  startedAt  DateTime  @default(now())
  expiresAt  DateTime?
  endedAt    DateTime?
  score      Int       @default(0)
  answers    Json      @default("{}")
  violations Json      @default("[]")
  createdAt  DateTime  @default(now())

  @@index([status, expiresAt])
}
